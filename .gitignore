# Karpathy layer 1 — raw sources are immutable. Both source types are TRACKED here:
#   - code repos    -> raw/code/<slug> as git SUBMODULES (this demo defaults to
#                      `acquire: submodule`); the committed gitlink + .gitmodules IS the pin.
#   - articles/docs -> raw/sources/ committed as the curated source of truth.
# So raw/ is NOT ignored. Only regenerable build artifacts are:

# Build artifacts: SCIP indexes, packets, reconcile state. Regenerable, never committed.
.cache/

# Claude Code reads skills only from .claude/skills/, but the canonical copy lives in
# .agents/skills/ (shared with Codex + Antigravity). install-skill.sh symlinks it here;
# don't commit the mirror — keep one source of truth visible in the tree.
/.claude/skills/

# Python
__pycache__/
*.pyc
.venv/
venv/

# NOTE: wiki/ is the PRODUCT here and IS committed (unlike in the wikify-repo tool repo).
